# Loaded at startup via `import 'dotenv/config'` in `src/app.module.ts`.
# Copy this file to `.env` in the project root. Shell-defined variables win over `.env`.

# HTTP server port (also embedded into default HCM_BASE_URL when unset).
PORT=3000

# SQLite database file path (TypeORM).
DATABASE_PATH=timeoff.sqlite

# Base URL for the HCM HTTP adapter (mock HCM is mounted at /mock-hcm in-process).
# Defaults to http://127.0.0.1:<PORT>/mock-hcm after startup when unset.
HCM_BASE_URL=http://127.0.0.1:3000/mock-hcm

# HTTP client timeout for HCM calls (ms).
HCM_TIMEOUT_MS=30000

# Set to `true` to log SQL from TypeORM.
TYPEORM_LOGGING=false

# Serialize POST /time-off-requests/:id/approve per employee+location (ms).
# See TRD.md §14.6 and §16.
APPROVAL_LOCK_TTL_MS=30000
APPROVAL_LOCK_ACQUIRE_TIMEOUT_MS=5000
APPROVAL_LOCK_RETRY_DELAY_MS=50

# Test helper only: set to `1` with `npm run test:e2e:detail` for per-test titles.
# E2E_VERBOSE=1
